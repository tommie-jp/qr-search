# SITE_ADDRESS: ローカルテストは localhost、本番は qr.tommie.jp
# Caddy が HTTPS 証明書の自動取得と http→https リダイレクトを行う
# (localhost の場合は内部 CA の自己署名証明書)
#
# 注意: 本番 (vps2) が使うのはこの Caddy ではなく既存の nginx (+ certbot)。
# ここは compose の proxy プロファイル専用で、本番の構成をローカルで再現するためのもの。
# 認証まわりを変えたら vps2 の nginx にも同じ設定を入れること (docs/05-PWA計画.md)。
{$SITE_ADDRESS:localhost} {
	# 画像アップロード (10MB) + multipart オーバーヘッドを許容しつつ、
	# 巨大ボディによるメモリ枯渇をエッジで遮断する。
	# handle の外に置いて全パスに効かせる: 下の @pwa_public は認証を外すため、
	# ここが handle の内側だと未認証のまま無制限のボディを投げ込めてしまう
	request_body {
		max_size 12MB
	}

	# PWA: ブラウザは manifest とアイコンを Authorization ヘッダなしで取得するため、
	# ここを認証下に置くと 401 になり「インストール可能」と判定されない。
	# どちらも秘密情報を含まないので公開してよい
	@pwa_public path /manifest.webmanifest /icon-*.png /apple-icon.png
	handle @pwa_public {
		reverse_proxy app:3000
	}

	handle {
		basic_auth {
			{$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
		}
		reverse_proxy app:3000
	}
}
