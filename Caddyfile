# SITE_ADDRESS: ローカルテストは localhost、本番は qr.tommie.jp
# Caddy が HTTPS 証明書の自動取得と http→https リダイレクトを行う
# (localhost の場合は内部 CA の自己署名証明書)
{$SITE_ADDRESS:localhost} {
	basic_auth {
		{$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
	}
	# 画像アップロード (10MB) + multipart オーバーヘッドを許容しつつ、
	# 巨大ボディによるメモリ枯渇をエッジで遮断する
	request_body {
		max_size 12MB
	}
	reverse_proxy app:3000
}
