# PostgreSQL のパスワード (compose.yaml と DATABASE_URL の両方で使う)
POSTGRES_PASSWORD=changeme

# Prisma / アプリの DB 接続先
DATABASE_URL=postgresql://qr:changeme@localhost:5432/qr

# 印刷する QR コードに埋め込む URL のベース
QR_BASE_URL=https://qr.tommie.jp

# 本番 (vps2) だけ production にする。ローカルは未設定のまま (空) にしておくこと。
# production 以外なら画面がピンクになりタイトルに [LOCAL] が付き、
# http://127.0.0.1:3000 を本番と誤認してデータを更新する事故を防ぐ。
# doDeploy.sh はデプロイ先の .env に APP_ENV=production があるか確認する
APP_ENV=

# JAN をスキャンしたとき商品名を引く Yahoo!ショッピングの Client ID (docs/14)
# https://developer.yahoo.co.jp/ でアプリ登録 (種別=サーバーサイド) して取得。
# 未設定なら商品情報を取得しないだけで、新規登録の導線は動く
YAHOO_SHOPPING_APP_ID=

# ISBN をスキャンしたとき書影を引く楽天ウェブサービスの設定 (docs/19)。
# https://webservice.rakuten.co.jp/app/list で確認する。**3 つとも要る**:
#   RAKUTEN_APP_ID     … アプリID
#   RAKUTEN_ACCESS_KEY … アクセスキー (pk_ で始まる。【NEW】で必須)
#   RAKUTEN_APP_ORIGIN … アプリ登録の「サイトURL」。Origin ヘッダとして送る。
#                        無いと 403、登録と違うと HTTP_REFERRER_NOT_ALLOWED
# 1 つでも欠けると引けないうえ、楽天のエラーはどれが原因か教えてくれない。
# 未設定なら openBD のホワイトリスト版元 (実測 1/11) の書影しか入らない。
# 書影が入らないだけで、書名・著者の事前入力は動く
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_APP_ORIGIN=https://qr.tommie.jp

# リバースプロキシ (Caddy)
# ローカルテストは localhost、本番は qr.tommie.jp
SITE_ADDRESS=localhost

# ログイン (docs/18-ログイン計画.md)
# 認証はエッジ (nginx / Caddy) ではなくアプリが行う。ログインしなくても
# ヘッダを出すためで、この 2 つが app の認証の正本。
# 未設定だと誰もログインできない (全ページが「ログインが必要です」になる)。
BASIC_AUTH_USER=changeme
#
# bcrypt ハッシュを base64 にして入れる。生の `$2b$12$…` を書いてはいけない —
# Next.js の env 読み込みが `$` を変数参照として展開し、値が黙って壊れる
# (60 文字が 6 文字になる。理由は src/lib/auth.ts のコメント)。
#
# 生成:
#   npm run hash-password
#
# パスワードを直接シェルに書かないこと ($ や ! が別物に化けて、
# 「思っていたのと違うパスワードのハッシュ」ができる)。上のコマンドは
# 端末から直接読み、コスト 12 で作って base64 まで済ませる。
BASIC_AUTH_HASH_B64=changeme

# パスキー (docs/29-パスキー計画.md §7)
# Face ID / Touch ID でログインするための設定。**両方揃って初めて有効**で、
# 欠けている間はパスキーの導線が出ないだけ (パスワードでは今までどおり入れる)。
#
# リクエストからは組み立てられないので env で渡す。アプリは nginx の内側に
# 居て http://0.0.0.0:3100 しか見えておらず、ブラウザが居る場所
# (https://qr.tommie.jp) を自分では知らないため。
#
#   本番:     WEBAUTHN_RP_ID=qr.tommie.jp
#             WEBAUTHN_ORIGIN=https://qr.tommie.jp
#   ローカル: WEBAUTHN_RP_ID=localhost
#             WEBAUTHN_ORIGIN=http://localhost:3000
#
# ローカルが http でよいのは localhost が WebAuthn の特例だから。
# **127.0.0.1 では動かない** (特例の対象は localhost という名前のほう)。
# RP_ID を後から変えると、登録済みのパスキーはすべて使えなくなる。
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=
