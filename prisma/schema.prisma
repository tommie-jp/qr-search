generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Ver1 (MongoDB) の item コレクションを引き継ぐ。
// itemNo は Ver1 の実データが文字列のため文字列主キー
// (印刷済み QR シールの URL 互換を最優先)。
// itemNoNum は数値ソート用 (非数字の itemNo は null)。
model Item {
  itemNo    String   @id @map("item_no")
  itemNoNum Int?     @map("item_no_num")
  memo      String   @default("")
  url       String   @default("")
  mode      Mode     @default(memo)
  // memo から抽出したタグ (正規化済み) の派生キャッシュ。検索・補完に使う。
  tags      String[] @default([])
  // memo のプロパティ行 (hFE=208 など) から抽出した派生キャッシュ。
  // [{ key, label, value }] の配列でタグ検索時の特性表に使う (src/lib/props.ts)。
  props     Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  // 最後にこのノートを開いた日時 (docs/37-アクセス順計画.md)。
  // ログイン中に /item・/edit を開いたときだけ進む。
  //
  // **updated_at と分けて持つのが要点**。「見ただけで更新順が動く」のは嘘に
  // なる (trashItems / setItemPublic が生 SQL で @updatedAt を避けているのと
  // 同じ考え方)。一方で ENEX から取り込んだノートは作成・更新日時が Evernote
  // 由来 (2012 年など) なので更新順では埋もれる。この列があると「最近触った
  // 順」で拾えて、取り込んだ日時も本文の日時も両方を正直に保てる。
  //
  // 既存行は移行時に updated_at で埋めた。null 許容にしないのは、並べ替えで
  // NULLS LAST の考慮が要らないため (初期値があれば最初は更新順と同じに
  // 見え、使うほどアクセス順に育つ)。
  accessedAt DateTime @default(now()) @map("accessed_at")
  // ゴミ箱 (二段階削除)。null = 通常、非 null = ゴミ箱行き日時。
  // 検索・タグ集計は null の行だけを見る。永久削除は行の DELETE。
  // ゴミ箱の行も items に残るため、nextItemNo の採番はその番号を
  // 自然に飛ばす (= 復元まで番号が予約される。docs/12-ゴミ箱計画.md §4)。
  deletedAt DateTime? @map("deleted_at")
  // 公開 (docs/22-ノート公開計画.md)。null = 非公開、非 null = 公開した日時。
  // 非 null のノートだけが、ログインしていない人にも /item/<itemNo> で開ける。
  // 判定の正本は src/lib/publicItem.ts の isPublicItem() で、ゴミ箱 (deleted_at
  // 非 null) の行はここが非 null でも公開しない。
  publicAt  DateTime? @map("public_at")

  @@index([itemNoNum])
  @@index([tags], type: Gin)
  @@map("items")
}

enum Mode {
  memo
  url
}

// memo に挿入した画像。ファイルシステム (volume) ではなく DB に持つことで、
// pg_dump だけでメモと画像が一緒に取れ、両者の整合が壊れないようにする。
// name は Ver2.x で発番済みの "UUID.拡張子" をそのまま引き継ぐ
// (既存メモ内の /api/images/<name> リンクを壊さないため)。
model Image {
  name      String   @id
  mime      String
  data      Bytes
  // 一覧のサムネイル (docs/23-検索結果表示モード計画.md §2)。data から作れる
  // 派生キャッシュで、形式は常に THUMB_MIME (src/lib/thumbnail.ts)。
  // null = 未生成。原寸のまま一覧に並べるとスマホ写真 1 枚が数 MB になるため、
  // 保存時に 1 度だけ作って持つ。null のときは配信側が原寸で代替するので、
  // 生成に失敗しても画像が割れることはない (遅くなるだけ)。
  thumb     Bytes?
  // 画像検索用の埋め込みベクトル (docs/25-画像検索計画.md §4)。data から作れる
  // 派生キャッシュで、Float32Array (正規化済み) をそのままバイト列にしたもの。
  // 形式・次元はモデルに従う (src/lib/embedding/model.ts の EMBEDDING_DIM)。
  // null = 未生成。thumb と同じく生成に失敗しても保存は成功させ、画像検索の
  // 対象から外れるだけにする。既存行は scripts/backfillEmbeddings.mjs で埋める。
  embedding Bytes?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("images")
}

// 登録済みパスキー (docs/29-パスキー計画.md §5)。
// 持つのは**公開鍵だけ**で、秘密鍵は端末 (Secure Enclave / iCloud キーチェーン)
// から出てこない。この表が漏れても成りすませない。
model WebAuthnCredential {
  // credential ID。認証器が振る識別子で、base64url 文字列のまま持つ
  id         String   @id
  // 登録した時点の利用者名。いまは 1 名だけ (docs/29 §11) だが、ログイン後に
  // ヘッダの帯へ出す名前をここから取ることで、env を後から変えても
  // 発行済みのパスキーが誰のものか分からなくなることがない
  userName   String   @map("user_name")
  publicKey  Bytes    @map("public_key")
  // 認証器が「何回使われたか」を申告する値。クローン検知に使うが、
  // 巻き戻りで即失効はさせない (docs/29 §9)。WebAuthn の仕様上 uint32 なので
  // Int (符号付き 32bit) では上半分が入らない。BigInt で持ち、
  // SimpleWebAuthn へ渡すときだけ Number() に落とす
  counter    BigInt   @default(0)
  // 認証器の接続手段 ('internal', 'hybrid' など)。次回ログイン時に
  // ブラウザへ返すと、どの手段で聞きに行くかの案内が正確になる
  transports String[] @default([])
  // 一覧で見分けるための名前 (「iPhone」など)。人が付ける
  label      String
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@map("webauthn_credentials")
}

// ログイン中の端末 (docs/29-パスキー計画.md §4)。
//
// 生のトークンはブラウザの Cookie にしか存在せず、ここには sha256 だけを置く。
// pg_dump が漏れてもセッションを乗っ取れないようにするため
// (パスワードのハッシュを env に持つのと同じ考え方)。
model Session {
  tokenHash String   @id @map("token_hash")
  // 利用者名。いまは BASIC_AUTH_USER の 1 名だけだが、ヘッダの帯に出す名前は
  // セッション自身が持つ (env を後から変えても、発行済みの帯が化けない)
  userName  String   @map("user_name")
  createdAt DateTime @default(now()) @map("created_at")
  // 90 日のスライディング。使うたびに延びる (延長は 1 日 1 回まで。docs/29 §4)
  expiresAt DateTime @map("expires_at")

  // 期限切れの掃除で範囲削除するため
  @@index([expiresAt])
  @@map("sessions")
}

// memo の ```circuitikz フェンスから描いた SVG のキャッシュ。
// 描画は TeX (WASM) の起動込みで 1 秒強かかる一方、memo は何度も表示され
// 内容はめったに変わらないため、本文のハッシュで引けるようにする。
// hash は sha256(レンダラ版 + ソース) で、レンダラ版を混ぜることで
// 描画結果が変わったときに古い SVG を返し続けないようにしている。
// 画像と同じく DB に置くことで pg_dump だけで丸ごと復元できる
// (消えても再描画できる派生キャッシュなので、消失しても実害はない)。
model CircuitSvg {
  hash      String   @id
  svg       String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("circuit_svgs")
}
