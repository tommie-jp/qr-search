# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client
/src/generated/

# .env.example はコミットする
!.env.example

# uploaded images (dev)
/data/

# doCopyDBfromVPS2.sh がローカル DB を上書きする前に取る退避ダンプ。
# 本番の実データ (メモ・画像) を含むため git 管理外
/backup/

# node-tikzjax の webfont (scripts/copyTikzFonts.mjs が node_modules から複製する)
/public/tikzjax

# スキャナの読み取りエンジン (scripts/copyZxingWasm.mjs が node_modules から複製する)
/public/zxing
